<h1>Welcome <%= user.username %></h1>
<button id="btn-logout">Log out</button>

<nav>
  <a href="/new-puzzle">Create a puzzle</a>
  <a href="/new-image">Upload an image</a>
</nav>

<section>
  <h2>Your puzzles</h2>
</section>

<section>
  <h2>Your images</h2>
  <%= images.length %>
  <% images.forEach(element => { %>
    <img src="<%= element.galleryPath %>"
  <% }) %>
</section>

<script type="module">
  const btn = document.getElementById("btn-logout");
    btn.addEventListener("click", (e) => {
      e.preventDefault();

      fetch("/logout?_method=delete", {
        method: 'POST',
      }).then(response => {
        if(response.redirected) {
          window.location.href = response.url
        }
      });
    });
</script>